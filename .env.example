# LLM Wiki – environment configuration
# Copy this file to .env and fill in your values.

# ── Authentication ────────────────────────────────────────────────────────────
# JWT secret for signing access tokens. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-please-use-openssl-rand-hex-32

# Access token lifetime (jose format: 15m, 1h, etc.)
# Default: 15m — short-lived, silently refreshed in background via refresh token
# JWT_ACCESS_EXPIRES_IN=15m

# Session duration: how long a user stays logged in without re-authenticating
# Default: 30 days. Decrease for stricter security (e.g. 7 for 1 week).
# JWT_REFRESH_EXPIRES_DAYS=30

# Refresh token cookie security flag.
# true  → only send cookie over HTTPS (required for production with TLS/nginx)
# false → send cookie over HTTP too (use for local HTTP deployments like Docker on localhost)
# Default: false (HTTP-friendly local deployment), auto-true if not set and NODE_ENV=production
# COOKIE_SECURE=false

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://llmwiki:password@localhost:5432/llmwiki

# ── Server ────────────────────────────────────────────────────────────────────
# Port the server listens on (default: 3001)
PORT=3001

# CORS origin – frontend dev server URL (only needed in development)
# CORS_ORIGIN=http://localhost:5173

# ── Storage ───────────────────────────────────────────────────────────────────
# (Docker volume paths are set in docker-compose.yml;
#  these are only needed when running outside Docker)

# Root directory where wiki projects are stored
# PROJECTS_ROOT=/data/projects

# Path for persistent app state (project registry, LLM settings, etc.)
# APP_STATE_PATH=/data/state/app-state.json
