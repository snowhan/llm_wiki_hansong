{
  "name": "llm-wiki",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc && vite build",
    "build:server": "cd server && npm run build",
    "preview": "vite preview",
    "start": "cd server && npm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:status-sync": "vitest run src/components/sources/__tests__/sources-view-status-sync.test.tsx src/components/sources/__tests__/sources-view-server-truth.test.tsx src/components/sources/__tests__/sources-view-ui-replay.test.tsx src/components/__tests__/activity-panel.test.tsx src/stores/__tests__/activity-store.test.ts src/commands/__tests__/ingest-sse-full.test.ts",
    "test:source-alignment": "vitest run src/components/__tests__/knowledge-tree.test.tsx src/components/__tests__/file-tree.test.tsx src/components/sources/__tests__/sources-view-status-sync.test.tsx src/components/sources/__tests__/sources-view-server-truth.test.tsx src/components/sources/__tests__/sources-view-ui-replay.test.tsx src/lib/__tests__/lint.test.ts --reporter=verbose",
    "test:preprocess": "vitest run src/components/__tests__/sources-view.test.tsx src/components/__tests__/create-project-dialog.test.tsx src/__tests__/app-projects-root.test.tsx && npm --prefix server test -- src/services/__tests__/preprocess-service.test.ts src/routes/__tests__/preprocess.test.ts",
    "test:ingest-regression": "vitest run src/lib/__tests__/ingest-full.test.ts src/commands/__tests__/ingest-sse-full.test.ts src/components/sources/__tests__/ingest-guards-full.test.ts src/components/sources/__tests__/sources-view-status-sync.test.tsx src/components/sources/__tests__/sources-view-server-truth.test.tsx src/stores/__tests__/activity-store-reload.test.ts && npm --prefix server test -- src/services/__tests__/ingest-service.test.ts src/services/__tests__/ingest-service-dedup.test.ts src/services/__tests__/ingest-service-title-sync.test.ts",
    "test:consistency": "npm --prefix server test -- src/services/__tests__/ingest-consistency.test.ts src/services/__tests__/ingest-timing.test.ts --reporter=verbose",
    "test:server-ingest-integration": "npm --prefix server test -- src/services/__tests__/ingest-write-regression.test.ts src/services/__tests__/rebuild-wiki-index.test.ts --reporter=verbose",
    "test:matrix": "bash scripts/test-matrix.sh",
    "test:soak": "bash scripts/test-soak.sh",
    "test:chaos": "bash scripts/test-chaos.sh",
    "test:parallel": "bash scripts/test-parallel.sh",
    "test:flake": "bash scripts/test-flake.sh",
    "test:hygiene": "bash scripts/test-hygiene.sh",
    "test:regression": "bash scripts/test-regression.sh",
    "test:title-sync": "bash scripts/test-title-sync.sh",
    "test:mapping-overview": "bash scripts/test-mapping-overview.sh",
    "test:ingest-count-gate": "bash scripts/test-ingest-count-gate.sh",
    "fixtures:sync": "node scripts/ingest-fixture-sync.mjs",
    "fixtures:seed": "node scripts/ingest-fixture-sync.mjs --seed-fallback-only",
    "pre-commit": "npm run test:ci -- --reporter=dot && npm --prefix server test -- --reporter=dot",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "cd server && tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@react-sigma/core": "^5.0.6",
    "@tiptap/extension-bubble-menu": "^3.22.3",
    "@tiptap/extension-code-block-lowlight": "^3.22.3",
    "@tiptap/extension-floating-menu": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-horizontal-rule": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-mathematics": "^3.22.3",
    "@tiptap/extension-subscript": "^3.22.3",
    "@tiptap/extension-superscript": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-of-contents": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/extension-unique-id": "^3.22.3",
    "@tiptap/html": "^3.22.3",
    "@tiptap/markdown": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/suggestion": "^3.22.4",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "i18next": "^26.0.3",
    "katex": "^0.16.45",
    "lowlight": "^3.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "sigma": "^3.0.2",
    "tippy.js": "^6.3.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.1.2",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
